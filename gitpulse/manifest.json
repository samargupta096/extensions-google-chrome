{
  "manifest_version": 3,
  "name": "GitPulse",
  "version": "1.0.0",
  "description": "AI-powered GitHub PR inbox — unified review dashboard, diff summaries, and velocity stats. 100% local, zero cloud.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "http://localhost:11434/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
