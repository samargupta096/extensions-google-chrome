{
  "manifest_version": 3,
  "name": "DeepWork Guardian",
  "version": "1.0.0",
  "description": "AI-powered focus timer, distraction blocking, and browsing analytics — 100% local, zero cloud",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": ["http://localhost:11434/*"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/blocker.js"],
      "css": ["content/blocker.css"],
      "run_at": "document_start"
    }
  ]
}
