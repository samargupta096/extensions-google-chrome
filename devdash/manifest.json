{
  "manifest_version": 3,
  "name": "DevDash",
  "version": "1.0",
  "description": "Developer productivity dashboard for your new tab.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "system.cpu",
    "system.memory",
    "declarativeNetRequest",
    "notifications",
    "alarms",
    "bookmarks",
    "management",
    "clipboardRead",
    "clipboardWrite",
    "sidePanel"
  ],
  "action": {
    "default_title": "Open DevDash",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "newtab.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/clipboard-monitor.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.npmjs.org/*",
    "https://hacker-news.firebaseio.com/*",
    "https://www.reddit.com/*",
    "https://api.github.com/*",
    "https://api.openweathermap.org/*",
    "https://api.stackexchange.com/*",
    "https://ghchart.rshah.org/*",
    "https://github-readme-stats.vercel.app/*",
    "https://github-readme-activity-graph.vercel.app/*",
    "https://api.openai.com/*",
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; img-src 'self' https://* data:;"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "devdash@samargupta096.github.io",
      "strict_min_version": "109.0"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "focus-dashboard/dashboard.html",
        "focus-dashboard/dashboard.css",
        "focus-dashboard/dashboard.js",
        "js/chart-utils.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
