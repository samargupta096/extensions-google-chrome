{
  "manifest_version": 3,
  "name": "ClipWise — Smart Clipboard Manager",
  "version": "1.0.0",
  "description": "AI-powered clipboard history, code snippets, and text enhancement — 100% local",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "declarativeNetRequest",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "http://127.0.0.1:11434/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.cursor.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  }
}