{
  "manifest_version": 3,
  "name": "StandupScribe",
  "version": "1.0.0",
  "description": "Auto-draft your daily standup from browsing activity. AI-powered Yesterday / Today / Blockers.",
  "permissions": ["tabs", "storage", "alarms", "notifications", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "StandupScribe",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
