{
  "manifest_version": 3,
  "name": "FlowForge — 5 Productivity Systems",
  "version": "1.0.0",
  "description": "Trigger System, Time Blocking, Deep Work, Momentum, and No Zero Days — all in one unified productivity engine. 100% local, zero cloud.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FlowForge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "externally_connectable": {
    "ids": ["*"]
  }
}
