{
  "manifest_version": 3,
  "name": "PriceHawk \u2014 Local Price Tracker",
  "version": "1.0.0",
  "description": "Track product prices locally, detect fake sales, and get AI deal analysis \u2014 zero data collection",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.cursor.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
