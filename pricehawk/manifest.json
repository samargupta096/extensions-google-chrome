{
  "manifest_version": 3,
  "name": "PriceHawk — Local Price Tracker",
  "version": "1.0.0",
  "description": "Track product prices locally, detect fake sales, and get AI deal analysis — zero data collection",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "permissions": ["activeTab", "storage", "alarms", "notifications"],
  "host_permissions": ["http://localhost:11434/*"],
  "background": { "service_worker": "background/service-worker.js" },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" }
  }
}
